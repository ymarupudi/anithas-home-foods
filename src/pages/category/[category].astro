---
import Base from '../../layouts/Base.astro';
import ProductCard from '../../components/ProductCard.astro';
import ProductSearch from '../../components/ProductSearch.astro';
import products from '../../data/products.json';
import categories from '../../data/categories.json';

export function getStaticPaths() {
  return categories.map((c) => ({
    params: { category: c.slug },
    props: { category: c },
  }));
}

const { category } = Astro.props;
const items = products.filter((p) => p.category === category.slug);
---
<Base title={category.name}>
  <section class="max-w-6xl mx-auto px-4 py-10">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6">
      <h1 class="text-3xl font-display font-bold">{category.emoji} {category.name}</h1>
      {items.length > 0 && <ProductSearch placeholder={`Search in ${category.name}...`} />}
    </div>
    {items.length === 0 ? (
      <p class="text-stone-500">No products in this category yet.</p>
    ) : (
      <>
        <div data-product-grid class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
          {items.map((p) => <ProductCard product={p} />)}
        </div>
        <p data-search-empty class="text-stone-500 mt-6" style="display:none">No products match your search.</p>
      </>
    )}
  </section>
</Base>
