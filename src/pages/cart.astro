---
import Base from '../layouts/Base.astro';
import site from '../data/site.json';
const base = import.meta.env.BASE_URL;
---
<Base title="Your Cart">
  <section class="max-w-4xl mx-auto px-4 py-10">
    <h1 class="text-3xl font-display font-bold mb-6">Your Cart</h1>

    <div id="empty-state" class="hidden text-center py-16">
      <p class="text-stone-500 text-lg">Your cart is empty.</p>
      <a href={`${base}shop/`} class="inline-block mt-4 bg-brand text-white px-6 py-3 rounded-full font-medium hover:bg-brand-dark transition">Browse Products</a>
    </div>

    <div id="cart-view" class="hidden">
      <div id="items" class="space-y-3"></div>

      <div class="mt-6 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 border-t pt-4">
        <button id="clear-btn" class="text-sm text-stone-500 hover:text-brand underline">Clear cart</button>
        <div class="text-right">
          <div class="text-stone-600 text-sm">Total</div>
          <div id="total" class="text-2xl font-bold text-brand-dark">₹0</div>
        </div>
      </div>

      <a id="order-btn" href="#" target="_blank" rel="noopener"
         class="mt-6 block text-center bg-green-600 text-white px-6 py-4 rounded-full font-semibold hover:bg-green-700 transition">
        Place Order on WhatsApp
      </a>
      <p class="text-xs text-stone-500 mt-2 text-center">Opens WhatsApp with all items and total pre-filled.</p>
    </div>
  </section>

  <script define:vars={{ whatsapp: site.whatsapp }}>
    const itemsEl    = document.getElementById('items');
    const totalEl    = document.getElementById('total');
    const orderBtn   = document.getElementById('order-btn');
    const clearBtn   = document.getElementById('clear-btn');
    const cartView   = document.getElementById('cart-view');
    const emptyState = document.getElementById('empty-state');

    const escape = (s) => String(s).replace(/[&<>"']/g, (c) => ({
      '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'
    }[c]));

    const render = () => {
      const items = window.Cart.read();

      if (items.length === 0) {
        cartView.classList.add('hidden');
        emptyState.classList.remove('hidden');
        return;
      }
      cartView.classList.remove('hidden');
      emptyState.classList.add('hidden');

      itemsEl.innerHTML = items.map((i) => `
        <div class="flex items-center gap-4 bg-white p-3 rounded-lg shadow-sm">
          <img src="${escape(i.image)}" alt="" class="w-16 h-16 object-cover rounded" />
          <div class="flex-1 min-w-0">
            <div class="font-semibold truncate">${escape(i.name)}</div>
            <div class="text-sm text-stone-500">${escape(i.weight)} — ₹${i.price}</div>
          </div>
          <div class="flex items-center gap-2">
            <button data-act="dec" data-slug="${escape(i.slug)}" data-weight="${escape(i.weight)}"
                    class="w-8 h-8 rounded border border-stone-300 hover:bg-stone-100">−</button>
            <span class="w-6 text-center">${i.qty}</span>
            <button data-act="inc" data-slug="${escape(i.slug)}" data-weight="${escape(i.weight)}"
                    class="w-8 h-8 rounded border border-stone-300 hover:bg-stone-100">+</button>
          </div>
          <div class="w-20 text-right font-medium">₹${i.price * i.qty}</div>
          <button data-act="rm" data-slug="${escape(i.slug)}" data-weight="${escape(i.weight)}"
                  class="text-stone-400 hover:text-brand" aria-label="Remove">✕</button>
        </div>
      `).join('');

      const total = window.Cart.total();
      totalEl.textContent = `₹${total}`;

      const lines = items.map((i) => `• ${i.name} (${i.weight}) x ${i.qty} — ₹${i.price * i.qty}`).join('\n');
      const msg = `Hi, I'd like to place an order:\n\n${lines}\n\nTotal: ₹${total}\n\nPlease confirm availability and delivery.`;
      orderBtn.href = `https://wa.me/${whatsapp}?text=${encodeURIComponent(msg)}`;
    };

    itemsEl.addEventListener('click', (e) => {
      const btn = e.target.closest('button[data-act]');
      if (!btn) return;
      const { act, slug, weight } = btn.dataset;
      const item = window.Cart.read().find((i) => i.slug === slug && i.weight === weight);
      if (!item) return;
      if (act === 'inc') window.Cart.setQty(slug, weight, item.qty + 1);
      if (act === 'dec') window.Cart.setQty(slug, weight, item.qty - 1);
      if (act === 'rm')  window.Cart.remove(slug, weight);
    });

    clearBtn.addEventListener('click', () => {
      if (confirm('Clear all items from cart?')) window.Cart.clear();
    });

    document.addEventListener('cart:change', render);
    document.addEventListener('cart:ready', render);
    if (window.Cart) render();
  </script>
</Base>
