---
const { product } = Astro.props;
const base = import.meta.env.BASE_URL;
const availableVariants = product.variants.filter((v) => v.inStock !== false);
const outOfStock = product.inStock === false || availableVariants.length === 0;
const minPrice = (outOfStock ? product.variants : availableVariants)
  .reduce((m, v) => Math.min(m, v.price), Infinity);
---
<a href={`${base}product/${product.slug}/`} data-product-name={product.name} class="product-card group block bg-white rounded-lg overflow-hidden shadow-sm hover:shadow-md transition relative">
  {outOfStock && (
    <span class="absolute top-2 left-2 z-10 bg-stone-800/85 text-white text-[10px] font-bold uppercase tracking-wide px-2 py-1 rounded">
      Out of Stock
    </span>
  )}
  <div class={`aspect-square overflow-hidden bg-stone-100 ${outOfStock ? 'opacity-60' : ''}`}>
    <img src={product.image} alt={product.name} loading="lazy"
         class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
  </div>
  <div class="p-3">
    <h3 class="font-semibold text-stone-800 group-hover:text-brand line-clamp-2">{product.name}</h3>
    <p class="text-sm text-stone-500 mt-1">From ₹{minPrice}</p>
  </div>
</a>
