---
import site from '../data/site.json';
const base = import.meta.env.BASE_URL;
const year = new Date().getFullYear();
---
<footer class="bg-stone-900 text-stone-200 mt-16">
  <div class="max-w-6xl mx-auto px-4 py-10 grid md:grid-cols-3 gap-8 text-sm">
    <div>
      <h3 class="font-display text-xl text-white mb-2">{site.name}</h3>
      <p class="text-stone-400">{site.tagline}</p>
    </div>
    <div>
      <h4 class="font-semibold text-white mb-2">Quick Links</h4>
      <ul class="space-y-1">
        <li><a href={base} class="hover:text-brand-light">Home</a></li>
        <li><a href={`${base}shop/`} class="hover:text-brand-light">Shop</a></li>
        <li><a href={`${base}about/`} class="hover:text-brand-light">About</a></li>
        <li><a href={`${base}contact/`} class="hover:text-brand-light">Contact</a></li>
      </ul>
    </div>
    <div>
      <h4 class="font-semibold text-white mb-2">Reach Us</h4>
      <p class="text-stone-400">{site.address}</p>
      <p class="mt-2">
        <a href={site.maps} target="_blank" rel="noopener"
           class="inline-flex items-center gap-1.5 text-stone-300 hover:text-brand-light"
           aria-label="View location on Google Maps">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          View on Google Maps
        </a>
      </p>
      <p class="mt-2">📞 <a href={`tel:${site.phone}`} class="hover:text-brand-light">{site.phone}</a></p>
      <p>✉️ <a href={`mailto:${site.email}`} class="hover:text-brand-light">{site.email}</a></p>
    </div>
  </div>
  <div class="border-t border-stone-800 text-center py-4 text-xs text-stone-500">
    © {year} {site.name}. All rights reserved.
  </div>
</footer>
